# Este .env é do AGENTE (roda no computador do colégio), separado do .env
# do app.py (que roda no Discloud). Copie para ".env" nesta mesma pasta.

# Endereço do site depois de hospedado no Discloud (ou no domínio que
# vocês configurarem). Sem a barra "/" no final.
CLOUD_URL=https://sua-app.discloud.app

# Precisa ser EXATAMENTE a mesma chave configurada no .env do app.py
# (variável AGENTE_API_KEY lá também). Gere uma com:
#   python -c "import secrets; print(secrets.token_hex(32))"
AGENTE_API_KEY=

# Cada quantos segundos o agente verifica se chegou pedido novo.
AGENTE_INTERVALO_SEGUNDOS=15
