# Copie este arquivo para ".env" (sem o ".example") e preencha com os
# valores reais. O ".env" NUNCA deve ser commitado no Git — ele já está
# protegido no .gitignore da raiz do projeto.

# ID do cliente OAuth do Google Workspace (não é secreto, mas fica mais
# fácil de trocar aqui do que editando o código).
GOOGLE_CLIENT_ID=314763396953-7imem6nh7na48ujfnbnb1ni79rvpcbn6.apps.googleusercontent.com

# Chave que o agente de impressão (no computador do colégio) usa para se
# autenticar nas rotas /api/agente/*. Precisa ser EXATAMENTE igual à
# AGENTE_API_KEY configurada no .env do agente_impressao.py. Gere uma com:
#   python -c "import secrets; print(secrets.token_hex(32))"
AGENTE_API_KEY=

# "true" liga o modo debug do Flask (NUNCA deixe true se o servidor for
# acessível pela rede do colégio — o debug do Flask permite execução de
# código arbitrário se alguém achar uma página de erro).
ACALANTO_DEBUG=false
