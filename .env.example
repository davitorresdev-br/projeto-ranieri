# Copie este arquivo para ".env" (sem o ".example") e preencha com os
# valores reais. O ".env" NUNCA deve ser commitado no Git — ele já está
# protegido no .gitignore da raiz do projeto.

# OBS: o login com Google Workspace foi desativado por enquanto (sem
# domínio próprio e HTTPS não dá para validar o OAuth com segurança). Por
# isso não há mais GOOGLE_CLIENT_ID aqui. Para reativar no futuro, restaure
# a rota /api/login/google no app.py e o botão no front-end.

# Chave que o agente de impressão (no computador do colégio) usa para se
# autenticar nas rotas /api/agente/*. Precisa ser EXATAMENTE igual à
# AGENTE_API_KEY configurada no .env do agente_impressao.py. Gere uma com:
#   python -c "import secrets; print(secrets.token_hex(32))"
AGENTE_API_KEY=

# "true" liga o modo debug do Flask (NUNCA deixe true se o servidor for
# acessível pela rede do colégio — o debug do Flask permite execução de
# código arbitrário se alguém achar uma página de erro).
ACALANTO_DEBUG=false

# Limpeza automática dos PDFs pesados, para o banco não crescer sem limite.
# Ao subir, o app apaga o ARQUIVO de pedidos já concluídos há mais de N dias
# — o registro leve (quem/o quê/quando/cópias) continua no histórico para
# sempre. 0 (padrão) = NÃO apaga nada automaticamente; nesse caso a limpeza
# só acontece quando o T.I. chama a rota POST /api/admin/limpar-pdfs.
# Ex.: 30 mantém os PDFs por ~1 mês e depois libera o espaço deles.
ACALANTO_RETENCAO_PDF_DIAS=0
