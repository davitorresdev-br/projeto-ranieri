# .env real do AGENTE (agente_impressao.py). Fica no computador do colégio.

# Por enquanto, apontando para o app.py rodando na própria máquina, pra
# você testar o fluxo completo (site -> banco -> agente -> impressora)
# antes de mexer com o Discloud. Troque para o endereço do Discloud
# quando ele estiver no ar.
CLOUD_URL=http://localhost:8080

# Chave gerada agora. IMPORTANTE: copie esse MESMO valor para dentro do
# seu .env real do app.py (a linha AGENTE_API_KEY= que já está lá) — os
# dois lados precisam ter exatamente a mesma chave, ou o agente recebe
# "Não autorizado" em tudo.
AGENTE_API_KEY=57cb048abc1992e02418243d30cae5d48a58f148f6e9bdfc4beb32c7d21dfcc6

AGENTE_INTERVALO_SEGUNDOS=15
